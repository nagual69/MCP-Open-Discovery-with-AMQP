{
  "name": "mcp-open-discovery",
  "version": "2.0.0",
  "description": "Networking Discovery tools exposed via Model Context Protocol - SDK Compatible",
  "main": "dist-ts/src/index.js",
  "scripts": {
    "start": "npm run build:ts && node dist-ts/src/main.js",
    "start-stdio": "set TRANSPORT_MODE=stdio&& npm run build:ts && node dist-ts/src/main.js",
    "start-http": "set TRANSPORT_MODE=http&& set HTTP_PORT=6270&& npm run build:ts && node dist-ts/src/main.js",
    "start-amqp": "set TRANSPORT_MODE=amqp&& npm run build:ts && node dist-ts/src/main.js",
    "start-http-amqp": "set TRANSPORT_MODE=http,amqp&& set HTTP_PORT=6270&& npm run build:ts && node dist-ts/src/main.js",
    "start-all": "set TRANSPORT_MODE=stdio,http,amqp&& set HTTP_PORT=6270&& npm run build:ts && node dist-ts/src/main.js",
    "start-both": "set TRANSPORT_MODE=http,amqp&& set HTTP_PORT=6270&& npm run build:ts && node dist-ts/src/main.js",
    "start-oauth": "set TRANSPORT_MODE=http&& set HTTP_PORT=6270&& set OAUTH_ENABLED=true&& npm run build:ts && node dist-ts/src/main.js",
    "test": "npm run build:ts && node testing/master_test_suite.js",
    "test:policy": "npm run build:ts && node testing/test_typed_policy_enforcements.js",
    "test:policy:typed": "npm run build:ts && node testing/test_typed_policy_enforcements.js",
    "test:policy:legacy": "node testing/test_policy_enforcements.js",
    "test:integrity:legacy": "node testing/test_plugin_integrity_and_policy.js",
    "test:http-session": "node testing/test_http_session_ttl.js http://localhost:6270",
    "test:http-session:docker": "node testing/test_http_session_ttl.js http://localhost:6270",
    "test:smoke": "npm run build:ts && node testing/master_test_suite.js --smoke",
    "test:amqp": "node testing/test-amqp-transport.js",
    "test:amqp:unit": "node testing/test-amqp-transport-unit.js",
    "test:audit": "npm run build:ts && node testing/audit_mcp_compliance.js",
    "test:zod": "node testing/test_native_zod_validation.js",
    "test:oauth": "node testing/test_oauth_implementation.js",
    "ui:test": "node testing/run_management_ui.js",
    "ui:serve": "node testing/run_management_ui.js --serve",
    "test:plugin-validation": "node testing/test_plugin_validation.js",
    "test:spec-plugin": "node testing/test_spec_plugin_e2e.js",
    "test:spec-plugin-deps": "node testing/test_spec_plugin_dependencies.js",
    "test-registry": "node testing/test_registry_register_from_db.js && node testing/test_registry_reregister_hot_reload.js",
    "build:ts": "npx tsc -p tsconfig.json",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "npx tsc -p tsconfig.strict.json --noEmit",
    "start:typed": "npm run build:ts && node dist-ts/src/main.js",
    "validate:typed-plugin-manager": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js",
    "validate:typed-plugin:net-utils": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js net-utils",
    "validate:typed-plugin:credentials": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js credentials",
    "validate:typed-plugin:marketplace": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js marketplace",
    "validate:typed-plugin:nmap": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js nmap",
    "validate:typed-plugin:proxmox": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js proxmox",
    "validate:typed-plugin:prompts": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js prompts",
    "validate:typed-plugin:registry-tools": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js registry-tools",
    "validate:typed-plugin:snmp": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js snmp",
    "validate:typed-plugin:zabbix": "npm run build:ts && node dist-ts/src/validate-typed-plugin-manager.js zabbix",
    "build:plugin:credentials": "npx tsc -p plugins/src/credentials/tsconfig.json",
    "build:plugin:marketplace": "npx tsc -p plugins/src/marketplace/tsconfig.json",
    "build:plugin:memory-cmdb": "npx tsc -p plugins/src/memory-cmdb/tsconfig.json",
    "build:plugin:net-utils": "npx tsc -p plugins/src/net-utils/tsconfig.json",
    "build:plugin:nmap": "npx tsc -p plugins/src/nmap/tsconfig.json",
    "build:plugin:proxmox": "npx tsc -p plugins/src/proxmox/tsconfig.json",
    "build:plugin:prompts": "npx tsc -p plugins/src/prompts/tsconfig.json",
    "build:plugin:registry-tools": "npx tsc -p plugins/src/registry-tools/tsconfig.json",
    "build:plugin:snmp": "npx tsc -p plugins/src/snmp/tsconfig.json",
    "build:plugin:zabbix": "npx tsc -p plugins/src/zabbix/tsconfig.json",
    "build:plugins:blessed": "node plugins/scripts/build-blessed-plugins.js",
    "health": "powershell -Command \"Invoke-WebRequest -Uri http://localhost:6270/health -UseBasicParsing\"",
    "migrate-credentials": "node tools/migrate_proxmox_credentials.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nagual69/mcp-open-discovery.git"
  },
  "keywords": [
    "mcp",
    "busybox",
    "networking",
    "tools",
    "container"
  ],
  "author": "Toby Schmeling",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/nagual69/mcp-open-discovery/issues"
  },
  "homepage": "https://github.com/nagual69/mcp-open-discovery#readme",
  "engines": {
    "node": ">=23"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "@types/amqplib": "^0.10.7",
    "adm-zip": "^0.5.10",
    "ajv": "^8.17.1",
    "amqplib": "^0.10.8",
    "axios": "^1.11.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "glob": "^11.0.3",
    "mcp-types": "^1.0.2",
    "net-snmp": "^3.10.1",
    "node-fetch": "^2.7.0",
    "ws": "^8.18.3",
    "zod": "^3.25.64",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "json-schema-to-zod": "^2.6.1"
  }
}
